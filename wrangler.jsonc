{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hn-reader",
  "compatibility_date": "2026-03-04",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "./worker/index.ts",
  "assets": {
    "directory": "dist/client",
    "not_found_handling": "none",
    "binding": "ASSETS"
  },
  "images": {
    "binding": "IMAGES"
  },
  "kv_namespaces": [
    {
      "binding": "VINEXT_CACHE",
      "id": "ad80ac118a4e4ca79bb62b5dceb9aa75"
    }
  ]
}
